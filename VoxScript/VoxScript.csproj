<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    
    <Title>VoxScript</Title>
    <Authors>Redvoxel Games</Authors>
    <Description>A basic scripting language</Description>
    <PackageProjectUrl>https://github.com/Redvoxel-Games/VoxScript</PackageProjectUrl>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <RepositoryUrl>https://github.com/Redvoxel-Games/VoxScript</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Version>1.0.5</Version>
    <PackageReleaseNotes>
      Fixed issue with external objects not giving function values for their methods despite having them stored.
      Added ScriptObject.HasKey(VoxValue).
      Added an error for when an attempt to call a non-function value (such as null) is made.
    </PackageReleaseNotes>
    <PackageTags>Language</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Antlr4.Runtime.Standard" Version="4.13.1" />
    <None Include="../README.md" Pack="true" PackagePath="\"/>
    <None Include="../LICENSE" Pack="true" PackagePath="\"/>
  </ItemGroup>

</Project>
