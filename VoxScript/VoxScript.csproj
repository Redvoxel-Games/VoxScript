<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <Title>VoxScript</Title>
    <Authors>Redvoxel Games</Authors>
    <Description>A basic scripting language</Description>
    <PackageProjectUrl>https://github.com/Redvoxel-Games/VoxScript</PackageProjectUrl>
    <PackageLicenseUrl>https://github.com/Redvoxel-Games/VoxScript/blob/master/LICENSE</PackageLicenseUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Antlr4.Runtime.Standard" Version="4.13.1" />
  </ItemGroup>

</Project>
